# ─── Supabase (REQUIRED) ─────────────────────────────────────────────────────
# Get from: supabase.com → Your Project → Settings → API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_KEY=your_anon_public_key_here

# ─── OpenSky Network (OPTIONAL) ──────────────────────────────────────────────
# Register free at: https://opensky-network.org/login
# Without credentials: anonymous access works but with lower rate limits
OPENSKY_USERNAME=
OPENSKY_PASSWORD=

# ─── Open-Meteo ──────────────────────────────────────────────────────────────
# NO KEY NEEDED — completely free, works out of the box

# ─── HOW TO USE ──────────────────────────────────────────────────────────────
# 1. Copy this file: cp .env.example .env
# 2. Fill in SUPABASE_URL and SUPABASE_KEY
# 3. Optionally add OpenSky credentials
# 4. Never commit .env to git!
